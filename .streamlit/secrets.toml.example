# .streamlit/secrets.toml — copy to secrets.toml and fill in values.
# This file is safe to commit. secrets.toml is gitignored.
#
# On Streamlit Community Cloud: paste the contents of secrets.toml
# into the app's Secrets panel (Settings → Secrets).
# On Render: set these as environment variables instead.

# Optional: set a password to protect the app from public access.
# If set, the app will prompt for this password on first load.
# Leave blank (or remove) to disable password protection.
APP_PASSWORD = ""
