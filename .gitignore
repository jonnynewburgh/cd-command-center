# Ignore raw data files (large downloads, state licensing files, etc.) but
# allow seed files that are small enough to commit and version in Git.
data/raw/*
!data/raw/state_programs_seed.csv
__pycache__/
*.pyc
*.pyo
.env
.venv/
venv/
Lib/
Scripts/
pyvenv.cfg
*.egg-info/
.DS_Store
*.log

# Claude Code local config
.claude/

# Streamlit secrets — never commit real passwords/keys
.streamlit/secrets.toml

# SQLite database — too large for GitHub (>100 MB); back up separately
data/cd_command_center.sqlite
data/cd_command_center.sqlite-shm
data/cd_command_center.sqlite-wal
data/cd_command_center.sqlite-journal
data/*.sqlite
data/*.db
