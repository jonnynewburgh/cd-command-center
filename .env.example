# CD Command Center — Required Environment Variables
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Database connection (SQLite path for local dev; PostgreSQL URL for production)
DATABASE_URL=data/cd_command_center.sqlite

# FRED API key (free) — required for market rate data (SOFR, Treasuries, Fed Funds)
# Get one at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Census Bureau API key (optional but recommended to avoid rate limits)
# Get one at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BLS API key (optional — increases rate limits for unemployment/QCEW data)
# Get one at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Federal Audit Clearinghouse API key (free) — required for fetch_fac.py
# Sign up at: https://api.data.gov/signup/
FAC_API_KEY=

# Head Start Enterprise System credentials — required for load_headstart_pir.py
# Account: https://hses.ohs.acf.hhs.gov
HSES_USERNAME=
HSES_PASSWORD=

# Shared secret required on write routes (POST/PUT/DELETE on /notes/*).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# The Next.js dashboard must send it as the X-API-Token header on write calls.
# If unset, writes are allowed (with a startup warning) — fine for local dev,
# not for production.
API_WRITE_TOKEN=

# Comma-separated allowed origins for the CORS layer. Leave blank to use the
# baked-in defaults (localhost:3000, localhost:5173, command-center.jhnadvising.com).
# Set on staging/preview deploys that need additional origins.
CORS_ORIGINS=
